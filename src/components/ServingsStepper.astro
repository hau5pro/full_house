---
interface Props {
  servings: number;
}

const { servings } = Astro.props;
---

<div class="servings-stepper" data-original={servings} data-current={servings}>
  <button class="stepper-btn" data-dir="-1" aria-label="Decrease servings">−</button>
  <span class="stepper-value meta-value">{servings}</span>
  <button class="stepper-btn" data-dir="1" aria-label="Increase servings">+</button>
</div>

<style>
  .servings-stepper {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .stepper-btn {
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--accent-warm-muted);
    border-radius: var(--border-radius-sm);
    color: var(--accent-warm);
    font-size: var(--text-base);
    line-height: 1;
    cursor: pointer;
    flex-shrink: 0;
    transition: all var(--transition-fast);
  }

  .stepper-btn:hover {
    background: var(--accent-warm-muted);
    color: var(--text);
  }

  .stepper-btn:disabled {
    opacity: 0.25;
    cursor: not-allowed;
    pointer-events: none;
  }
</style>
